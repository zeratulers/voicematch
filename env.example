# VoiceMatch 环境变量配置
# 复制此文件为 .env 并修改相应的值

# 数据库配置
MYSQL_ROOT_PASSWORD=voicematch123
MYSQL_DATABASE=voicematch
MYSQL_USER=voicematch
MYSQL_PASSWORD=voicematch123

# 应用基本设置
APP_NAME=VoiceMatch术中语音指令播放系统
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT配置
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# CORS配置
CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1

# 存储配置
STORAGE_BACKEND=local
AUDIO_STORAGE_PATH=./data/audio

# MinIO配置（当STORAGE_BACKEND为minio时使用）
MINIO_ROOT_USER=voicematch
MINIO_ROOT_PASSWORD=voicematch123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=voicematch
MINIO_SECRET_KEY=voicematch123
MINIO_BUCKET=voicematch-audio
MINIO_SECURE=false

# 文件上传限制
MAX_UPLOAD_SIZE=52428800
MAX_AUDIO_DURATION=300
ALLOWED_AUDIO_FORMATS=wav,mp3,opus,m4a,webm

# 数据保留配置
RETENTION_DAYS=365

# 安全配置
BCRYPT_ROUNDS=12
