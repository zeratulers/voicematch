# 数据库配置
# 选择数据库类型：mysql 或 sqlite
DATABASE_URL=mysql+aiomysql://voicematch:voicematch123@localhost:3306/voicematch
# 或者使用 SQLite：
# DATABASE_URL=sqlite+aiosqlite:///./voicematch.db

# MySQL 配置（当使用 MySQL 时）
MYSQL_ROOT_PASSWORD=voicematch123
MYSQL_DATABASE=voicematch
MYSQL_USER=voicematch
MYSQL_PASSWORD=voicematch123

# 应用密钥（生产环境必须修改）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
SECRET_KEY=your-super-secret-key-change-this-in-production

# 存储配置
# 存储后端：local 或 minio
STORAGE_BACKEND=local

# MinIO 配置（当 STORAGE_BACKEND=minio 时使用）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=voicematch
MINIO_SECRET_KEY=voicematch123
MINIO_BUCKET=voicematch-audio
MINIO_SECURE=false
MINIO_ROOT_USER=voicematch
MINIO_ROOT_PASSWORD=voicematch123

# 应用配置
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# JWT 配置
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# 文件上传限制
MAX_UPLOAD_SIZE=52428800  # 50MB
MAX_AUDIO_DURATION=300    # 5分钟
ALLOWED_AUDIO_FORMATS=["wav","mp3","opus","m4a"]

# 数据保留配置
RETENTION_DAYS=365

# 安全配置
BCRYPT_ROUNDS=12

# 本地音频存储路径（当 STORAGE_BACKEND=local 时使用）
AUDIO_STORAGE_PATH=./data/audio
